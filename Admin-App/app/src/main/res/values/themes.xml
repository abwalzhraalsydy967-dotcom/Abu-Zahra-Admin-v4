<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AbuZahraAdmin" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.AbuZahraAdmin.Login" parent="Theme.AbuZahraAdmin">
        <item name="android:windowBackground">@color/primary</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <style name="Theme.AbuZahraAdmin.Splash" parent="Theme.AbuZahraAdmin">
        <item name="android:windowBackground">@color/primary</item>
    </style>

    <style name="Widget.AbuZahraAdmin.CardView" parent="">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="contentPadding">@dimen/padding_md</item>
    </style>

    <style name="Widget.AbuZahraAdmin.StatusDot" parent="">
        <item name="android:width">@dimen/status_dot_size</item>
        <item name="android:height">@dimen/status_dot_size</item>
    </style>

    <style name="Widget.AbuZahraAdmin.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
    </style>

    <style name="Widget.AbuZahraAdmin.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.AbuZahraAdmin.Button.Primary" parent="Widget.AbuZahraAdmin.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
    </style>

    <style name="Widget.AbuZahraAdmin.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">@dimen/radius_sm</item>
    </style>

    <style name="Widget.AbuZahraAdmin.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/on_surface</item>
        <item name="itemTextColor">@color/on_surface</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="TextAppearance.AbuZahraAdmin.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.AbuZahraAdmin.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.AbuZahraAdmin.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_hint</item>
    </style>
</resources>