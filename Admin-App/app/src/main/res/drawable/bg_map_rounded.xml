<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded background for the location map WebView container.
     The actual corner clipping is applied in code via ViewOutlineProvider +
     setClipToOutline(true) on the FrameLayout; this drawable just provides
     a coloured fill so the container is visible while the map tiles load. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/surface_variant" />
    <corners android:radius="@dimen/radius_md" />
</shape>
