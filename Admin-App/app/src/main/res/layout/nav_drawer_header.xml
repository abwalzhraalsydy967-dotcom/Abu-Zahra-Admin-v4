<?xml version="1.0" encoding="utf-8"?>
<!--
    Custom Navigation Drawer header for Abu-Zahra Admin App.
    Matches the web sidebar's footer (user avatar + username + email + role badge).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/primary_dark"
    android:fitsSystemWindows="true"
    android:paddingTop="24dp">

    <!-- Brand row: shield logo + app name -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/padding_md"
        android:paddingBottom="@dimen/padding_md">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_shield_logo">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                app:tint="@color/on_primary" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/margin_sm"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="أبو زهرة"
                android:textSize="16sp"
                android:textColor="@color/on_primary"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="لوحة التحكم الإدارية"
                android:textSize="11sp"
                android:textColor="@color/login_subtitle" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- User info row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/padding_md"
        android:paddingVertical="@dimen/padding_md">

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp">

            <TextView
                android:id="@+id/tvAvatarInitial"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_device_icon"
                android:gravity="center"
                android:text="م"
                android:textSize="20sp"
                android:textColor="@color/on_primary"
                android:fontFamily="sans-serif-medium" />

            <View
                android:id="@+id/statusDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="bottom|start"
                android:background="@drawable/bg_status_dot"
                android:backgroundTint="@color/online_color" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/margin_sm"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDrawerUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مستخدم"
                android:textSize="14sp"
                android:textColor="@color/on_primary"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvDrawerUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:maxLines="1"
                android:ellipsize="end"
                android:textDirection="ltr" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDrawerRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/role_admin"
            android:textSize="10sp"
            android:textColor="@color/login_subtitle"
            android:background="@drawable/bg_role_chip"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Online/Events badge row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/padding_md"
        android:paddingBottom="@dimen/padding_sm">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_drawer_badge"
            android:padding="8dp"
            android:layout_marginEnd="4dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_status_dot"
                android:backgroundTint="@color/online_color" />

            <TextView
                android:id="@+id/tvBadgeOnline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 متصل"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_drawer_badge"
            android:padding="8dp"
            android:layout_marginStart="4dp">

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_activity"
                app:tint="@color/warning" />

            <TextView
                android:id="@+id/tvBadgeEvents"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 حدث"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="6dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
