<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Dark Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/login_emerald_light"
            app:title="إنشاء حساب جديد"
            app:titleTextColor="@color/text_primary"
            app:subtitleTextColor="@color/login_subtitle" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <!-- Register Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_login_card"
                    android:padding="28dp"
                    android:paddingTop="24dp">

                    <!-- Info about email verification -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/login_input_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="20dp">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="0"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvVerifyInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📨 سيتم إرسال رسالة تحقق إلى بريدك الإلكتروني بعد إنشاء الحساب"
                            android:textSize="13sp"
                            android:textColor="@color/login_emerald_light"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:lineSpacingExtra="2dp" />

                    </LinearLayout>

                    <!-- Username Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilUsername"
                        style="@style/Widget.AbuZahraAdmin.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="اسم المستخدم"
                        android:layout_marginBottom="16dp"
                        app:hintTextColor="@color/login_emerald"
                        app:boxStrokeColor="@color/login_emerald"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/login_emerald"
                        app:endIconMode="clear_text">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etUsername"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textPersonName"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/login_input_hint"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEmail"
                        style="@style/Widget.AbuZahraAdmin.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="البريد الإلكتروني"
                        android:layout_marginBottom="16dp"
                        app:hintTextColor="@color/login_emerald"
                        app:boxStrokeColor="@color/login_emerald"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/login_emerald"
                        app:endIconMode="clear_text">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textEmailAddress"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/login_input_hint"
                            android:textDirection="ltr"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPassword"
                        style="@style/Widget.AbuZahraAdmin.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="كلمة المرور"
                        android:layout_marginBottom="16dp"
                        app:hintTextColor="@color/login_emerald"
                        app:boxStrokeColor="@color/login_emerald"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/login_emerald"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/login_emerald">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/login_input_hint"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Confirm Password Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilConfirmPassword"
                        style="@style/Widget.AbuZahraAdmin.TextInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="تأكيد كلمة المرور"
                        android:layout_marginBottom="6dp"
                        app:hintTextColor="@color/login_emerald"
                        app:boxStrokeColor="@color/login_emerald"
                        app:boxStrokeWidth="1.5dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/login_emerald"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/login_emerald">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/login_input_hint"
                            android:textSize="15sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Error Message -->
                    <TextView
                        android:id="@+id/tvError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/error"
                        android:textSize="13sp"
                        android:visibility="gone"
                        android:layout_marginBottom="6dp"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Loading Progress -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:indeterminate="true"
                        android:visibility="gone"
                        app:indicatorColor="@color/login_emerald"
                        app:trackColor="@color/login_input_bg"
                        app:trackCornerRadius="4dp" />

                    <!-- Register Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegister"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_login_button"
                        android:backgroundTint="@null"
                        android:text="إنشاء الحساب"
                        android:textSize="16sp"
                        android:textColor="@color/on_primary"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.02"
                        android:elevation="6dp"
                        android:stateListAnimator="@null"
                        app:cornerRadius="14dp"
                        app:backgroundTint="@null" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </ScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
