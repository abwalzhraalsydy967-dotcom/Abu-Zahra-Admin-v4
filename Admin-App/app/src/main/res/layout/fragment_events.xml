<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="@dimen/padding_md">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/margin_md">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_events"
                android:textSize="22sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="سجل أحداث النظام"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefresh"
            style="@style/Widget.AbuZahraAdmin.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/refresh"
            android:textColor="@color/text_secondary"
            app:icon="@drawable/ic_refresh"
            app:iconTint="@color/text_secondary"
            app:backgroundTint="@color/surface_variant"
            app:strokeColor="@color/card_stroke"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <!-- Filter chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/levelFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:layout_marginBottom="@dimen/margin_sm">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAll"
            style="@style/Widget.AbuZahraAdmin.Chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/all"
            android:checked="true"
            app:chipBackgroundColor="@color/surface_variant" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipInfo"
            style="@style/Widget.AbuZahraAdmin.Chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="معلومة"
            app:chipBackgroundColor="@color/surface_variant" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSuccess"
            style="@style/Widget.AbuZahraAdmin.Chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نجاح"
            app:chipBackgroundColor="@color/surface_variant" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipWarning"
            style="@style/Widget.AbuZahraAdmin.Chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تحذير"
            app:chipBackgroundColor="@color/surface_variant" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipError"
            style="@style/Widget.AbuZahraAdmin.Chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="خطأ"
            app:chipBackgroundColor="@color/surface_variant" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Search bar -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.AbuZahraAdmin.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_sm"
        app:startIconDrawable="@drawable/ic_search"
        app:startIconTint="@color/text_hint"
        app:boxBackgroundColor="@color/surface_variant"
        app:boxStrokeColor="@color/card_stroke"
        app:hintTextColor="@color/text_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ابحث في الأحداث..."
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Events list -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/eventsSwipe"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvEvents"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="24dp" />

            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔔"
                    android:textSize="56sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="لا توجد أحداث"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
