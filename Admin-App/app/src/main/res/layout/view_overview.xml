<?xml version="1.0" encoding="utf-8"?>
<!--
    Overview view for Abu-Zahra Admin dashboard.
    Matches the web's OverviewView component:
      - Page header (title + refresh button)
      - 4 stat cards (online/total devices, total commands, total events, total users)
      - System status row (server status + total users + active streams)
      - Recent events list
      - Recent devices list
      - Online vs offline summary
      - Quick actions (link code + tg link)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/overviewSwipe"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/margin_md"
                android:paddingTop="@dimen/margin_md"
                android:paddingBottom="40dp">

                <!-- Page header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/margin_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/overview_title"
                            android:textSize="@dimen/text_headline"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/overview_subtitle"
                            android:textSize="@dimen/text_caption"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOverviewRefresh"
                        style="@style/Widget.Material3.Button.TextButton.Icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/refresh"
                        android:textColor="@color/text_secondary"
                        app:icon="@drawable/ic_refresh"
                        app:iconSize="16dp"
                        app:iconTint="@color/text_secondary" />
                </LinearLayout>

                <!-- Stat cards grid: 2 columns -->
                <androidx.gridlayout.widget.GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/margin_md"
                    app:columnCount="2"
                    app:rowCount="2"
                    app:orientation="horizontal">

                    <!-- Online Devices -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_columnWeight="1"
                        app:layout_gravity="fill_horizontal"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="@dimen/card_elevation"
                        app:cardBackgroundColor="@color/surface"
                        app:strokeColor="#1A10B981"
                        app:strokeWidth="1dp"
                        android:layout_margin="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_md">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_phone"
                                    app:tint="@color/online_color" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/hint_online"
                                    android:textSize="10sp"
                                    android:textColor="@color/online_color"
                                    android:layout_marginStart="6dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvStatOnline"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 / 0"
                                android:textSize="22sp"
                                android:textColor="@color/online_color"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stat_online_devices"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Total Commands -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_columnWeight="1"
                        app:layout_gravity="fill_horizontal"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="@dimen/card_elevation"
                        app:cardBackgroundColor="@color/surface"
                        app:strokeColor="#1A10B981"
                        app:strokeWidth="1dp"
                        android:layout_margin="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_md">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_terminal"
                                    app:tint="@color/secondary" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/cat_control"
                                    android:textSize="10sp"
                                    android:textColor="@color/secondary"
                                    android:layout_marginStart="6dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvStatCommands"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textColor="@color/secondary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stat_total_commands"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Total Events -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_columnWeight="1"
                        app:layout_gravity="fill_horizontal"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="@dimen/card_elevation"
                        app:cardBackgroundColor="@color/surface"
                        app:strokeColor="#1AF59E0B"
                        app:strokeWidth="1dp"
                        android:layout_margin="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_md">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_activity"
                                    app:tint="@color/warning" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/events"
                                    android:textSize="10sp"
                                    android:textColor="@color/warning"
                                    android:layout_marginStart="6dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvStatEvents"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textColor="@color/warning"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stat_total_events"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Total Users -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        app:layout_columnWeight="1"
                        app:layout_gravity="fill_horizontal"
                        app:cardCornerRadius="@dimen/radius_md"
                        app:cardElevation="@dimen/card_elevation"
                        app:cardBackgroundColor="@color/surface"
                        app:strokeColor="#1A38BDF8"
                        app:strokeWidth="1dp"
                        android:layout_margin="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/padding_md">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_people"
                                    app:tint="@color/info" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/users"
                                    android:textSize="10sp"
                                    android:textColor="@color/info"
                                    android:layout_marginStart="6dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvStatUsers"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="22sp"
                                android:textColor="@color/info"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/stat_total_users"
                                android:textSize="@dimen/text_caption"
                                android:textColor="@color/text_secondary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </androidx.gridlayout.widget.GridLayout>

                <!-- Quick actions row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/margin_md">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLinkCodeAction"
                        style="@style/Widget.Material3.Button.TonalButton.Icon"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="@string/link_code_action"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_lock"
                        app:cornerRadius="@dimen/radius_sm" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTgLinkAction"
                        style="@style/Widget.Material3.Button.TonalButton.Icon"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="@string/tg_link_action"
                        android:textSize="12sp"
                        app:icon="@drawable/ic_command"
                        app:cornerRadius="@dimen/radius_sm" />
                </LinearLayout>

                <!-- Recent devices card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/margin_md"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardBackgroundColor="@color/surface"
                    app:cardElevation="@dimen/card_elevation">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_md">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/margin_sm">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_phone"
                                app:tint="@color/secondary" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/recent_devices"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginStart="6dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnViewAllDevices"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/view_all"
                                android:textColor="@color/secondary"
                                android:textSize="11sp"
                                android:minHeight="0dp"
                                android:minWidth="0dp"
                                android:padding="0dp" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <!-- Recent devices list -->
                            <LinearLayout
                                android:id="@+id/recentDevicesList"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical" />

                            <!-- Empty state -->
                            <LinearLayout
                                android:id="@+id/recentDevicesEmpty"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="24dp"
                                android:visibility="gone">

                                <ImageView
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:src="@drawable/ic_devices"
                                    app:tint="@color/text_hint"
                                    android:alpha="0.5"
                                    android:layout_marginBottom="@dimen/margin_sm" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/no_recent_devices"
                                    android:textSize="@dimen/text_caption"
                                    android:textColor="@color/text_hint" />
                            </LinearLayout>
                        </FrameLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Recent events card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/margin_md"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardBackgroundColor="@color/surface"
                    app:cardElevation="@dimen/card_elevation">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_md">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/margin_sm">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_activity"
                                app:tint="@color/warning" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/recent_events"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginStart="6dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnViewAllEvents"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/view_all"
                                android:textColor="@color/secondary"
                                android:textSize="11sp"
                                android:minHeight="0dp"
                                android:minWidth="0dp"
                                android:padding="0dp" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:id="@+id/recentEventsList"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical" />

                            <LinearLayout
                                android:id="@+id/recentEventsEmpty"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="24dp"
                                android:visibility="gone">

                                <ImageView
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:src="@drawable/ic_activity"
                                    app:tint="@color/text_hint"
                                    android:alpha="0.5"
                                    android:layout_marginBottom="@dimen/margin_sm" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/no_recent_activity"
                                    android:textSize="@dimen/text_caption"
                                    android:textColor="@color/text_hint" />
                            </LinearLayout>
                        </FrameLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Online vs offline summary -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/margin_md"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardBackgroundColor="@color/surface"
                    app:cardElevation="@dimen/card_elevation">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_md">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/margin_sm">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_phone"
                                app:tint="@color/secondary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/status"
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginStart="6dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:background="@drawable/bg_status_summary_online"
                                android:padding="@dimen/padding_md"
                                android:layout_marginEnd="4dp">

                                <TextView
                                    android:id="@+id/tvOnlineCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="22sp"
                                    android:textColor="@color/online_color"
                                    android:fontFamily="sans-serif-medium" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/online"
                                    android:textSize="11sp"
                                    android:textColor="@color/online_color" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:background="@drawable/bg_status_summary_offline"
                                android:padding="@dimen/padding_md"
                                android:layout_marginStart="4dp">

                                <TextView
                                    android:id="@+id/tvOfflineCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="22sp"
                                    android:textColor="@color/offline_color"
                                    android:fontFamily="sans-serif-medium" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/offline"
                                    android:textSize="11sp"
                                    android:textColor="@color/offline_color" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/overviewLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true" />
    </FrameLayout>

</LinearLayout>
