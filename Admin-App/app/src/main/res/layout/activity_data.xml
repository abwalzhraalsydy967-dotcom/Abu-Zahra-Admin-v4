<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="البيانات" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvSelectedDevice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="جاري تحميل الأجهزة..."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:padding="12dp"
                android:background="@color/surface"
                android:layout_marginBottom="16dp"
                android:drawablePadding="8dp" />

            <androidx.recyclerview.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="3"
                app:rowCount="4"
                app:useDefaultMargins="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSms"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="الرسائل\nالقصيرة"
                    android:textSize="12sp"
                    app:layout_columnWeight="1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCalls"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="سجل\nالمكالمات"
                    android:textSize="12sp"
                    app:layout_columnWeight="1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnContacts"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="جهات\nالاتصال"
                    android:textSize="12sp"
                    app:layout_columnWeight="1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLocation"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="الموقع\nالحالي"
                    android:textSize="12sp"
                    app:layout_columnWeight="1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNotifications"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="الإشعارات"
                    android:textSize="12sp"
                    app:layout_columnWeight="1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClipboard"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="الحافظة"
                    android:textSize="12sp"
                    app:layout_columnWeight="1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBattery"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="البطارية"
                    android:textSize="12sp"
                    app:layout_columnWeight="1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeviceInfo"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="معلومات\nالجهاز"
                    android:textSize="12sp"
                    app:layout_columnWeight="1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWifi"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="شبكات\nWi-Fi"
                    android:textSize="12sp"
                    app:layout_columnWeight="1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApps"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="التطبيقات\nالمثبتة"
                    android:textSize="12sp"
                    app:layout_columnWeight="1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBrowser"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="سجل\nالمتصفح"
                    android:textSize="12sp"
                    app:layout_columnWeight="1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCalendar"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:text="التقويم"
                    android:textSize="12sp"
                    app:layout_columnWeight="1"
                    app:cornerRadius="12dp" />

            </androidx.recyclerview.widget.GridLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>