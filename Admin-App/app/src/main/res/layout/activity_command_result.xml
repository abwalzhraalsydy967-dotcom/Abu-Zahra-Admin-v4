<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:fitsSystemWindows="true"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/command_result_title"
            app:titleTextColor="@color/text_primary"
            app:navigationIcon="@drawable/ic_back" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/margin_xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/margin_md">

                <!-- Status Card: command name + status + timing -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/margin_md"
                    app:cardCornerRadius="@dimen/radius_md"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardBackgroundColor="@color/surface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_md">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/ivCommandIcon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_command"
                                android:layout_marginEnd="@dimen/margin_md"
                                app:tint="@color/secondary" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvCommandName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="@dimen/text_body_large"
                                    android:textColor="@color/text_primary"
                                    android:fontFamily="sans-serif-medium" />

                                <TextView
                                    android:id="@+id/tvCommandKey"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="@dimen/text_small"
                                    android:textColor="@color/text_hint"
                                    android:layout_marginTop="2dp"
                                    android:textDirection="ltr" />

                            </LinearLayout>

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipStatus"
                                style="Widget.Material3.Chip.Assist"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pending"
                                android:textSize="@dimen/text_small"
                                android:clickable="false"
                                android:checkable="false" />

                        </LinearLayout>

                        <!-- Timing info -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="@dimen/margin_sm">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/sent_at"
                                    android:textSize="@dimen/text_small"
                                    android:textColor="@color/text_hint" />

                                <TextView
                                    android:id="@+id/tvSentAt"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="@dimen/text_caption"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/completed_at"
                                    android:textSize="@dimen/text_small"
                                    android:textColor="@color/text_hint" />

                                <TextView
                                    android:id="@+id/tvCompletedAt"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="@dimen/text_caption"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/duration"
                                    android:textSize="@dimen/text_small"
                                    android:textColor="@color/text_hint" />

                                <TextView
                                    android:id="@+id/tvDuration"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="@dimen/text_caption"
                                    android:textColor="@color/text_secondary"
                                    android:layout_marginTop="2dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Action buttons row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/margin_md">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRefresh"
                        style="Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/refresh"
                        app:icon="@drawable/ic_search"
                        app:iconGravity="textStart"
                        android:layout_marginEnd="@dimen/margin_xs" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopy"
                        style="Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="@string/copy"
                        app:icon="@drawable/ic_upload"
                        app:iconGravity="textStart"
                        android:layout_marginStart="@dimen/margin_xs" />

                </LinearLayout>

                <!-- Loading view: shown while polling for the result -->
                <LinearLayout
                    android:id="@+id/loadingView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/padding_lg"
                    android:visibility="visible">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:indeterminate="true" />

                    <TextView
                        android:id="@+id/tvLoadingMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/loading_result"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="@dimen/margin_md" />

                    <TextView
                        android:id="@+id/tvPollHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/polling_hint"
                        android:textSize="@dimen/text_small"
                        android:textColor="@color/text_hint"
                        android:layout_marginTop="@dimen/margin_xs" />

                </LinearLayout>

                <!-- Error view -->
                <LinearLayout
                    android:id="@+id/errorView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="@dimen/padding_lg"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvErrorTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/error"
                        android:textSize="@dimen/text_body_large"
                        android:textColor="@color/error" />

                    <TextView
                        android:id="@+id/tvErrorMessage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/text_body"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:layout_marginTop="@dimen/margin_sm" />

                </LinearLayout>

                <!-- Result summary (count / type label) -->
                <TextView
                    android:id="@+id/tvResultSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_body"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="@dimen/margin_sm"
                    android:visibility="gone" />

                <!-- Results host: RecyclerView or custom view added dynamically -->
                <FrameLayout
                    android:id="@+id/resultsHost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Snackbar slot -->
    <FrameLayout
        android:id="@+id/snackbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
