<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/padding_sm"
    android:paddingStart="0dp"
    android:gravity="center_vertical"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true">

    <!-- Selection checkbox (visible only in multi-select mode) -->
    <ImageView
        android:id="@+id/ivCheck"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_check_box_outline"
        android:padding="2dp"
        android:layout_marginEnd="@dimen/margin_xs"
        android:visibility="gone"
        app:tint="@color/secondary"
        android:contentDescription="تحديد" />

    <!-- File Type Icon -->
    <ImageView
        android:id="@+id/ivFileIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_file"
        android:padding="6dp"
        android:layout_marginEnd="@dimen/margin_md"
        app:tint="@color/secondary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_body"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            android:textDirection="ltr" />

        <TextView
            android:id="@+id/tvFileDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_hint"
            android:layout_marginTop="2dp"
            android:textDirection="ltr" />

    </LinearLayout>

    <!-- Download Button -->
    <ImageView
        android:id="@+id/ivDownload"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_download"
        android:padding="6dp"
        android:background="?android:attr/selectableItemBackgroundBorderless" />

</LinearLayout>
