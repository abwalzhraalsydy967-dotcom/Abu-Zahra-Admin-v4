<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/padding_sm"
    android:paddingStart="0dp"
    android:gravity="center_vertical"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true">

    <!-- Selection checkbox (visible only in multi-select mode) -->
    <ImageView
        android:id="@+id/ivCheck"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_check_box_outline"
        android:padding="2dp"
        android:layout_marginEnd="@dimen/margin_xs"
        android:visibility="gone"
        app:tint="@color/secondary"
        android:contentDescription="تحديد" />

    <!-- File Type Icon -->
    <ImageView
        android:id="@+id/ivFileIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_file"
        android:padding="6dp"
        android:layout_marginEnd="@dimen/margin_md"
        app:tint="@color/secondary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_body"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:textDirection="ltr" />

        <TextView
            android:id="@+id/tvFileDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_hint"
            android:layout_marginTop="2dp"
            android:textDirection="ltr" />

    </LinearLayout>

    <!--
        Thumbnail slot (48dp). Shown only for image/video files that have a
        server-side file id (i.e. downloadable files in the requested-files
        list or files in the device filesystem browser whose server response
        included an `id`). When no thumbnail is available the slot is hidden
        and the leading file-type icon alone identifies the file.
    -->
    <FrameLayout
        android:id="@+id/thumbSlot"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="@dimen/margin_xs"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/surface_variant"
            android:contentDescription="@string/files" />

        <!-- Small play badge overlay for video thumbnails. -->
        <ImageView
            android:id="@+id/ivPlayBadge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_file_play"
            android:alpha="0.9"
            android:visibility="gone"
            app:tint="@color/on_primary" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/thumbProgress"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorSize="18dp"
            app:trackThickness="2dp" />

    </FrameLayout>

    <!-- Download Button -->
    <ImageView
        android:id="@+id/ivDownload"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_download"
        android:padding="6dp"
        android:background="?android:attr/selectableItemBackgroundBorderless" />

</LinearLayout>
