<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="@dimen/padding_md">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/margin_md">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_streaming"
                android:textSize="22sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="بث الشاشة والكاميرا والصوت"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Device selector -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDeviceSelected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_md"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="#1A10B981"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSelectedDeviceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="لم يتم اختيار جهاز"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvSelectedDeviceMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="اضغط لاختيار جهاز"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangeDevice"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تغيير"
                android:textColor="@color/secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Stream viewer card (live view) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/streamCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="@dimen/margin_md"
        app:cardBackgroundColor="@android:color/black"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/card_stroke"
        app:strokeWidth="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Live frame ImageView -->
            <ImageView
                android:id="@+id/ivFrame"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:background="@android:color/black"
                android:visibility="gone" />

            <!-- Idle state -->
            <LinearLayout
                android:id="@+id/idleState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📡"
                    android:textSize="64sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="اختر نوع البث للبدء"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- Connecting state -->
            <LinearLayout
                android:id="@+id/connectingState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#CC000000"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvConnectingIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📡"
                    android:textSize="48sp"
                    android:alpha="0.8" />

                <TextView
                    android:id="@+id/tvConnectingLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="جارٍ الاقتران..."
                    android:textColor="@color/secondary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tvConnectingMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الجودة: 720p • الجهاز: جارٍ التهيئة"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginHorizontal="48dp"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/secondary" />
            </LinearLayout>

            <!-- Live HUD overlay -->
            <LinearLayout
                android:id="@+id/liveHud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="top|start"
                android:padding="8dp"
                android:background="#80000000"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_status_dot"
                        android:backgroundTint="@color/error" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" LIVE"
                        android:textColor="@color/error"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvFps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FPS: 0"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvLatency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Latency: -"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvResolution"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Live controls -->
            <LinearLayout
                android:id="@+id/liveControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="horizontal"
                android:padding="8dp"
                android:background="#80000000"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStop"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="إيقاف"
                    android:textColor="@color/on_primary"
                    app:backgroundTint="@color/error"
                    app:icon="@drawable/ic_block"
                    app:iconTint="@color/on_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSwitchCamera"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="تبديل"
                    android:textColor="@color/on_primary"
                    app:backgroundTint="@color/surface_variant"
                    app:icon="@drawable/ic_radio"
                    app:iconTint="@color/on_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnScreenshot"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="لقطة"
                    android:textColor="@color/on_primary"
                    app:backgroundTint="@color/surface_variant"
                    app:icon="@drawable/ic_screenshot"
                    app:iconTint="@color/on_primary" />
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Quality selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/margin_sm">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الجودة:"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_gravity="center_vertical" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/qualityGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:chipSpacingHorizontal="4dp"
            android:layout_marginStart="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip480"
                style="@style/Widget.AbuZahraAdmin.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="480p"
                app:chipBackgroundColor="@color/surface_variant" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip720"
                style="@style/Widget.AbuZahraAdmin.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="720p"
                android:checked="true"
                app:chipBackgroundColor="@color/surface_variant" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip1080"
                style="@style/Widget.AbuZahraAdmin.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1080p"
                app:chipBackgroundColor="@color/surface_variant" />
        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

    <!-- Stream type cards -->
    <androidx.gridlayout.widget.GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        app:orientation="horizontal"
        app:useDefaultMargins="true">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStreamScreen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_columnWeight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#1A10B981"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖥️"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="بث الشاشة"
                    android:textColor="@color/secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStreamFront"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_columnWeight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#1A38BDF8"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤳"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الكاميرا الأمامية"
                    android:textColor="@color/info"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStreamBack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_columnWeight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#1A9C27B0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الكاميرا الخلفية"
                    android:textColor="#A78BFA"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStreamAudio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_columnWeight="1"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#1AE91E63"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎙️"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="بث الصوت"
                    android:textColor="@color/error"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.gridlayout.widget.GridLayout>

</LinearLayout>
