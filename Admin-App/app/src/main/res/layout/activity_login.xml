<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:paddingBottom="8dp">

        <!-- Top spacing for status bar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.6" />

        <!-- Logo Area -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="28dp">

            <!-- Shield Icon Circle -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_shield_logo" />

                <View
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:background="@android:drawable/ic_lock_lock" />

            </FrameLayout>

            <!-- App Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="أبو زهرة"
                android:textSize="36sp"
                android:textColor="@color/on_primary"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.02"
                android:shadowColor="#10B98140"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="8"
                android:layout_marginBottom="6dp" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="لوحة التحكم"
                android:textSize="15sp"
                android:textColor="@color/login_subtitle"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08" />

        </LinearLayout>

        <!-- Login Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_login_card"
                android:padding="28dp"
                android:paddingTop="24dp">

                <!-- Card Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تسجيل الدخول"
                    android:textSize="22sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="24dp" />

                <!-- Email Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/Widget.AbuZahraAdmin.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="البريد الإلكتروني"
                    android:layout_marginBottom="16dp"
                    app:hintTextColor="@color/login_emerald"
                    app:boxStrokeColor="@color/login_emerald"
                    app:boxStrokeWidth="1.5dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:startIconDrawable="@drawable/ic_person"
                    app:startIconTint="@color/login_emerald"
                    app:endIconMode="clear_text">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="textEmailAddress"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/login_input_hint"
                        android:textDirection="ltr"
                        android:textSize="15sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.AbuZahraAdmin.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="كلمة المرور"
                    android:layout_marginBottom="6dp"
                    app:hintTextColor="@color/login_emerald"
                    app:boxStrokeColor="@color/login_emerald"
                    app:boxStrokeWidth="1.5dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/login_emerald"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/login_emerald">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/login_input_hint"
                        android:textSize="15sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Error Message -->
                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/error"
                    android:textSize="13sp"
                    android:visibility="gone"
                    android:layout_marginBottom="6dp"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:fontFamily="sans-serif-medium" />

                <!-- Loading Progress -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:indicatorColor="@color/login_emerald"
                    app:trackColor="@color/login_input_bg"
                    app:trackCornerRadius="4dp" />

                <!-- Login Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_login_button"
                    android:backgroundTint="@null"
                    android:text="تسجيل الدخول"
                    android:textSize="16sp"
                    android:textColor="@color/on_primary"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.02"
                    android:elevation="6dp"
                    android:stateListAnimator="@null"
                    app:cornerRadius="14dp"
                    app:backgroundTint="@null"
                    android:layout_marginBottom="20dp" />

                <!-- Or Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_divider" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أو"
                        android:textColor="@color/login_input_hint"
                        android:paddingHorizontal="16dp"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_divider" />
                </LinearLayout>

                <!-- Google Sign-In Button -->
                <LinearLayout
                    android:id="@+id/btnGoogleSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_google_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="20dp"
                    android:foreground="?attr/selectableItemBackground">

                    <!-- Google "G" icon built with 4 colored squares -->
                    <LinearLayout
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:orientation="horizontal"
                        android:layout_marginEnd="12dp">

                        <!-- Blue (top-left) -->
                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@color/google_blue" />
                        <!-- Red (top-right) -->
                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@color/google_red" />
                        <!-- Yellow (bottom-left) -->
                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@color/google_yellow" />
                        <!-- Green (bottom-right) -->
                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@color/google_green" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تسجيل الدخول بحساب جوجل"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>

                <!-- Create Account -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateAccount"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="إنشاء حساب جديد"
                    android:textSize="14sp"
                    android:textColor="@color/login_emerald_light"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Debug Log Panel -->
        <LinearLayout
            android:id="@+id/debugPanel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.4"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/bg_debug_panel"
            android:padding="12dp"
            android:visibility="visible">

            <!-- Debug Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@color/login_emerald"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="سجل التشخيص"
                    android:textSize="12sp"
                    android:textColor="@color/login_debug_text"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <ScrollView
                android:id="@+id/debugLogScroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/debugLogText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="@color/login_debug_text"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp" />

            </ScrollView>

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
