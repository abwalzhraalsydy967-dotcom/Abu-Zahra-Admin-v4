<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="@dimen/padding_md">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/margin_md">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_commands"
                android:textSize="22sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مكتبة أوامر الجهاز — جميع الأوامر المتاحة"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Device selector (or "no device selected" prompt) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDeviceSelected"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_sm"
        app:cardBackgroundColor="@color/card_background"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="#1A10B981"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSelectedDeviceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="لم يتم اختيار جهاز"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvSelectedDeviceMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="اضغط لاختيار جهاز"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangeDevice"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تغيير"
                android:textColor="@color/secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Search box -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.AbuZahraAdmin.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/margin_sm"
        app:startIconDrawable="@drawable/ic_search"
        app:startIconTint="@color/text_hint"
        app:boxBackgroundColor="@color/surface_variant"
        app:boxStrokeColor="@color/card_stroke"
        app:hintTextColor="@color/text_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCommandSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ابحث عن أمر..."
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Category chips (horizontal scroll) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="@dimen/margin_sm">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:chipSpacingHorizontal="6dp" />
    </HorizontalScrollView>

    <!-- Command count -->
    <TextView
        android:id="@+id/tvCommandCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 أمر متاح"
        android:textColor="@color/text_hint"
        android:textSize="11sp"
        android:layout_marginBottom="@dimen/margin_sm" />

    <!-- Commands list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCommands"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="24dp" />

</LinearLayout>
