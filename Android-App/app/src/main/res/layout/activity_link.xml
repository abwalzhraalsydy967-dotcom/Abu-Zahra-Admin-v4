<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/linkRootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#0a0a0f">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🟥 Abu-Zahra"
        android:textSize="28sp"
        android:textColor="#E63946"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remote Admin Control"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/textDeviceId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Device ID: ..."
        android:textSize="12sp"
        android:textColor="#60a5fa"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/editCode"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/input_bg"
        android:hint="Enter Link Code"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:textSize="18sp"
        android:textAllCaps="true"
        android:gravity="center"
        android:letterSpacing="0.2"
        android:inputType="textCapCharacters"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/editServer"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/input_bg"
        android:hint="Server URL (optional)"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/btnLink"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="🔗 Link Device"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/button_bg"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/textStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#888888" />

</LinearLayout>
